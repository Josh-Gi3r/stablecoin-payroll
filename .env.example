# ─── Required ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — zero config for local dev)
#   file:./dev.db              — local SQLite
#   libsql://your-db.turso.io  — remote libsql/Turso (set DATABASE_AUTH_TOKEN below)
DATABASE_URL=file:./dev.db
# Auth token for remote libsql/Turso. Leave blank for local file DB.
DATABASE_AUTH_TOKEN=

# ─── Demo Seed ─────────────────────────────────────────────────────────────────
# Pin the seed password for repeatable dev logins.
# If unset, seed generates a random password and prints it to console.
# Set VITE_DEMO_PASSWORD to the same value so the persona switcher auto-login works.
SEED_PASSWORD=
VITE_DEMO_PASSWORD=

# ─── Operator Identity ─────────────────────────────────────────────────────────
# Displayed as the platform operator name throughout the UI.
OPERATOR_TENANT_ID=tnt-operator
OPERATOR_NAME=Payroll Platform

# ─── Document Storage (optional) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=payroll-documents

# ─── Settlement Provider (optional) ────────────────────────────────────────────
# Plug in your own on-chain settlement adapter.
SETTLEMENT_PROVIDER_API_URL=
SETTLEMENT_PROVIDER_API_KEY=

# ─── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@example.com

# ─── Port ──────────────────────────────────────────────────────────────────────
PORT=3000
